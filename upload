#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CONFIG_FILE="${SCRIPT_DIR}/.env"

if [[ ! -f "$CONFIG_FILE" ]]; then
  echo "Config not found at $CONFIG_FILE"
  echo "Create it with UPLOAD_URL and UPLOAD_KEY"
  exit 1
fi

source "$CONFIG_FILE"

AUTH_HEADER="Authorization: Bearer ${UPLOAD_KEY}"

usage() {
  echo "Usage: upload-image [-s scope] [-d desc] <file>"
  echo "       upload-image list [-s scope]"
  echo "       upload-image scopes"
  echo "       upload-image delete [-s scope] <filename>"
  echo ""
  echo "Commands:"
  echo "  (default)  Upload an image, returns URL"
  echo "  list       List all images in a scope"
  echo "  scopes     List available scopes and their access rules"
  echo "  delete     Delete an image by filename (e.g. abc123.png)"
  echo ""
  echo "Options:"
  echo "  -s SCOPE   Scope name (default: gh)"
  echo "  -d DESC    Description for the upload"
  echo "  -h         Show this help"
  exit 0
}

SCOPE="gh"
DESC=""
COMMAND=""

# Check for subcommand
case "${1:-}" in
  list)   COMMAND="list"; shift ;;
  scopes) COMMAND="scopes"; shift ;;
  delete) COMMAND="delete"; shift ;;
  -*)     COMMAND="upload" ;;
  "")     usage ;;
  *)      COMMAND="upload" ;;
esac

while getopts "s:d:h" opt; do
  case "$opt" in
    s) SCOPE="$OPTARG" ;;
    d) DESC="$OPTARG" ;;
    h) usage ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

check_response() {
  local response="$1"
  local http_code expected_code="$2"
  http_code=$(echo "$response" | tail -1)
  local body
  body=$(echo "$response" | sed '$d')
  if [[ "$http_code" -ne "$expected_code" ]]; then
    echo "Error (HTTP $http_code): $body" >&2
    exit 1
  fi
  echo "$body"
}

case "$COMMAND" in
  upload)
    if [[ $# -ne 1 ]]; then usage; fi
    FILE="$1"
    if [[ ! -f "$FILE" ]]; then
      echo "Error: file not found: $FILE" >&2
      exit 1
    fi

    CURL_ARGS=(-s -w "\n%{http_code}" -F "file=@${FILE}" -H "$AUTH_HEADER")
    if [[ -n "$DESC" ]]; then
      CURL_ARGS+=(-F "description=${DESC}")
    fi

    RESPONSE=$(curl "${CURL_ARGS[@]}" "${UPLOAD_URL}/upload/${SCOPE}")
    BODY=$(check_response "$RESPONSE" 200)
    echo "$BODY" | jq -r '.url'
    ;;

  list)
    RESPONSE=$(curl -s -w "\n%{http_code}" -H "$AUTH_HEADER" "${UPLOAD_URL}/api/${SCOPE}")
    BODY=$(check_response "$RESPONSE" 200)
    echo "$BODY" | jq -r '.[] | [.uploaded, .url, (.description // "-")] | @tsv' | column -t -s $'\t'
    ;;

  scopes)
    RESPONSE=$(curl -s -w "\n%{http_code}" -H "$AUTH_HEADER" "${UPLOAD_URL}/api/scopes")
    BODY=$(check_response "$RESPONSE" 200)
    echo "$BODY" | jq -r 'to_entries[] | "\(.key)\t\(.value.description)"' | column -t -s $'\t'
    ;;

  delete)
    if [[ $# -ne 1 ]]; then
      echo "Usage: upload-image delete [-s scope] <filename>" >&2
      exit 1
    fi
    FILENAME="$1"
    RESPONSE=$(curl -s -w "\n%{http_code}" -X DELETE -H "$AUTH_HEADER" "${UPLOAD_URL}/api/${SCOPE}/${FILENAME}")
    BODY=$(check_response "$RESPONSE" 200)
    echo "Deleted: $(echo "$BODY" | jq -r '.deleted')"
    ;;
esac
